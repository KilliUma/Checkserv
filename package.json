{
  "name": "wearcheck-platform",
  "version": "1.0.0",
  "private": true,
  "description": "WearCheck Online System - Plataforma Modular de Análise de Fluidos e Monitoramento",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "git:auto": "sh ./scripts/git-auto.sh",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@turbo/gen": "^2.0.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": "20.x",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "canvas",
      "core-js-pure",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ],
    "overrides": {
      "eslint": "^8.57.0"
    }
  }
}
